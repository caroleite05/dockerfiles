{
  "template": {
    "name": "{{tool_name}}",
    "description": "{{description}}",
    "status": "{{status}}",
    "recommended": [
      {
        "version": "{{recommended_version}}",
        "date": "{{recommended_version_date}}"
      }
    ],
    "latest": "{{latest_version}}",
    "bug_found": "{{bug_found}}",
    "not_working": "{{not_working}}",
    "no_longer_tested": "{{no_longer_tested}}",
    "manual_url": "{{manual_url}}",
    "source_url": "{{source_url}}",
    "comments": "{{comments}}",
    "gui": "{{gui}}",
    "gui_command": "{{gui_command}}",
    "podman": "{{podman}}",
    "singularity": "{{singularity}}",
    "invocation_general": "{{invocation_general}}",
    "usual_invocation_specific": "{{usual_invocation_specific}}",
    "usual_invocation_specific_comments": [
      "{{usual_invocation_specific_comments}}"
    ],
    "test_invocation_specific": "{{test_invocation}}",
    "test_data_url": "{{test_data_url}}",
    "test_results_url": "{{test_results_url}}",
    "icon": "{{icon_url}}",
    "input_data_type": [
      "{{input_data_type}}"
    ],
    "auto_tests": [
      {
        "docker_image": "{{docker_image}}",
        "input_files": [
          "{{input_file}}"
        ],
        "output_dir": "{{output_dir}}",
        "output_file": "{{output_file}}",
        "add_config": "{{add_configs}}",
        "commands": "{{commands}}",
        "time_seconds": "{{time_seconds}}"
      }
    ],
    "custom_searches": {
      "pubmed": "term={{pubmed}}",
      "scholar": "q={{scholar}}",
      "bioprotocol": "content={{bioprotocol}}",
      "bioprotocol_exchange": "content={{bioprotocol_exchange}}"
    }
  },
  "schema_rules": {
    "required_fields": [
      "tool_name",
      "description",
      "status",
      "recommended_version",
      "latest_version",
      "manual_url",
      "source_url",
      "gui",
      "invocation_general",
      "usual_invocation_specific",
      "test_invocation",
      "input_data_type",
      "pubmed",
      "scholar",
      "bioprotocol",
      "bioprotocol_exchange"
    ],
    "conditional_fields": {
      "gui_command": {
        "depends_on": "gui",
        "value": true
      }
    },
    "hidden_fields": [
      "test_data_url",
      "test_results_url"
    ]
  },
  "placeholder_hints": {
    "tool_name": "e.g. clustalomega",
    "description": "e.g. Predicting 3D structures of protein",
    "status": "Usable/Not Recommended/Updated",
    "recommended_version_date": "dd/mm/yyyy",
    "manual_url": "https://github.com/user/tool",
    "source_url": "https://github.com/user/tool",
    "podman": "untested/supported/unsupported",
    "singularity": "untested/supported/unsupported",
    "invocation_general": "docker run --rm -v /your/data/dir:/data",
    "input_data_type": "fasta, pdb, txt",
    "docker_image": "e.g. pegi3s/tool:1.0"
  },
  "field_groups": {
    "Essential Information": [
        "tool_name", "description", "status", "recommended_version", 
        "recommended_version_date", "latest_version", "bug_found", 
        "not_working", "no_longer_tested", "manual_url", "source_url", "comments"
    ],
    "Commands & Invocation": [
        "gui", "gui_command", "podman", "singularity", "invocation_general", 
        "usual_invocation_specific", "usual_invocation_specific_comments", 
        "test_invocation", "icon_url", "input_data_type"
    ],
    "Auto-Tests": [
        "docker_image", "input_file", "output_dir", "output_file", 
        "add_configs", "commands", "time_seconds"
    ],
    "Custom Searches": [
        "pubmed", "scholar", "bioprotocol", "bioprotocol_exchange"
    ]
  }
}